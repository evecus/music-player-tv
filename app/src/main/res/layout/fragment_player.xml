<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/player_bg">

    <!-- Left: Cover art panel -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/ivCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_default_cover_large" />

        <!-- Gradient overlay on cover -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_cover_overlay" />

        <!-- Quality badge over cover -->
        <TextView
            android:id="@+id/tvQuality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="16dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_quality_badge_dark" />
    </FrameLayout>

    <!-- Right: Controls panel -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@color/player_right_bg">

        <!-- Song info -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:selected="true" />

        <TextView
            android:id="@+id/tvArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:layout_marginTop="4dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- Lyrics area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="24dp">

            <com.tvmusic.app.ui.player.LyricsView
                android:id="@+id/lyricsView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvNoLyrics"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="暂无歌词"
                android:textColor="@color/text_tertiary"
                android:textSize="14sp"
                android:gravity="center"
                android:visibility="visible" />
        </FrameLayout>

        <!-- Seek bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1000"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent"
                android:focusable="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvPosition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <View android:layout_width="0dp" android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Playback controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp">

            <ImageButton
                android:id="@+id/btnShuffle"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_shuffle"
                android:background="@drawable/bg_ctrl_btn"
                android:tint="@color/text_primary"
                android:focusable="true"
                android:contentDescription="随机播放" />

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_skip_prev"
                android:background="@drawable/bg_ctrl_btn"
                android:tint="@color/text_primary"
                android:focusable="true"
                android:layout_marginStart="12dp"
                android:contentDescription="上一曲" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/bg_play_btn"
                android:tint="@color/bg_primary"
                android:focusable="true"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="播放/暂停" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_skip_next"
                android:background="@drawable/bg_ctrl_btn"
                android:tint="@color/text_primary"
                android:focusable="true"
                android:layout_marginEnd="12dp"
                android:contentDescription="下一曲" />

            <ImageButton
                android:id="@+id/btnRepeat"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_repeat_off"
                android:background="@drawable/bg_ctrl_btn"
                android:tint="@color/text_primary"
                android:focusable="true"
                android:contentDescription="循环模式" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
